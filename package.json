{
  "name": "chrome-tab-group-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm run test:run && npm run build",
    "build": "vite build",
    "dev": "vite build --watch",
    "setup:e2e": "playwright install chromium",
    "package": "npm run build && node scripts/package-extension.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "npm run build && playwright test",
    "verify:prod": "npm run check && npm run e2e && npm run package"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/chrome": "^0.0.314",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.9"
  }
}
